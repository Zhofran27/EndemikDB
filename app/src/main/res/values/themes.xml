<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EndemikDB" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
    </style>

    <style name="TextAppearance.EndemikDB.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
    </style>

    <style name="TextAppearance.EndemikDB.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextAppearance.EndemikDB.CardTitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.EndemikDB.CardSub" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">@color/text_accent</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>